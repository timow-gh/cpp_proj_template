{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "conf-common",
      "description": "General settings that apply to all configurations",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23",
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },
    {
      "name": "conf-windows-common",
      "description": "Windows settings for MSBuild toolchain.",
      "hidden": true,
      "inherits": "conf-common",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    },
    {
      "name": "conf-unixlike-common",
      "description": "Unix-like OS settings for gcc and clang toolchains",
      "hidden": true,
      "inherits": "conf-common",
      "condition": {
        "type": "inList",
        "string": "${hostSystemName}",
        "list": [
          "Linux",
          "Darwin"
        ]
      },
      "vendor": {
        "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
          "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
        }
      }
    },
    {
      "name": "conf-unixlike-clang-common",
      "description": "Common settings for clang compiler on Unix-like OS",
      "hidden": true,
      "inherits": "conf-unixlike-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-20",
        "CMAKE_CXX_COMPILER": "clang++-20",
        "CMAKE_CXX_FLAGS": "-stdlib=libstdc++"
      }
    },
    {
      "name": "conf-unixlike-gcc-common",
      "description": "Common settings for gcc compiler on Unix-like OS",
      "hidden": true,
      "inherits": "conf-unixlike-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "msvc Debug (User Mode)",
      "description": "Target Windows with the msvc compiler, debug build type",
      "inherits": "conf-windows-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "msvc Release (User Mode)",
      "description": "Target Windows with the msvc compiler, release build type",
      "inherits": "conf-windows-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "unixlike-gcc-debug",
      "displayName": "gcc Debug",
      "description": "Target Unix-like OS with the gcc compiler, debug build type",
      "inherits": "conf-unixlike-gcc-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "unixlike-gcc-relwithdebinfo",
      "displayName": "gcc RelWithDebInfo",
      "description": "Target Unix-like OS with the gcc compiler, release with debug info build type",
      "inherits": "conf-unixlike-gcc-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "unixlike-gcc-release",
      "displayName": "gcc Release",
      "description": "Target Unix-like OS with the gcc compiler, release build type",
      "inherits": "conf-unixlike-gcc-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "unixlike-clang-debug",
      "displayName": "clang Debug",
      "description": "Target Unix-like OS with the clang compiler, debug build type",
      "inherits": "conf-unixlike-clang-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "unixlike-clang-reldebug",
      "displayName": "clang RelWithDebInfo",
      "description": "Target Unix-like OS with the clang compiler, release with debug info build type",
      "inherits": "conf-unixlike-clang-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "unixlike-clang-release",
      "displayName": "clang Release",
      "description": "Target Unix-like OS with the clang compiler, release build type",
      "inherits": "conf-unixlike-clang-common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "jobs": 0
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "jobs": 0
    },
    {
      "name": "unixlike-gcc-debug",
      "configurePreset": "unixlike-gcc-debug",
      "jobs": 0
    },
    {
      "name": "unixlike-gcc-relwithdebinfo",
      "configurePreset": "unixlike-gcc-relwithdebinfo",
      "jobs": 0
    },
    {
      "name": "unixlike-gcc-release",
      "configurePreset": "unixlike-gcc-release",
      "jobs": 0
    },
    {
      "name": "unixlike-clang-debug",
      "configurePreset": "unixlike-clang-debug",
      "jobs": 0
    },
    {
      "name": "unixlike-clang-reldebug",
      "configurePreset": "unixlike-clang-reldebug",
      "jobs": 0
    },
    {
      "name": "unixlike-clang-release",
      "configurePreset": "unixlike-clang-release",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "test-common",
      "description": "Test CMake settings that apply to all configurations",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    },
    {
      "name": "test-windows-msvc-debug",
      "displayName": "Strict",
      "description": "Enable output and stop on failure",
      "inherits": "test-common",
      "configurePreset": "windows-msvc-debug"
    },
    {
      "name": "test-windows-msvc-release",
      "displayName": "Strict",
      "description": "Enable output and stop on failure",
      "inherits": "test-common",
      "configurePreset": "windows-msvc-release"
    },
    {
      "name": "test-unixlike-gcc-debug",
      "displayName": "Strict",
      "description": "Enable output and stop on failure",
      "inherits": "test-common",
      "configurePreset": "unixlike-gcc-debug"
    },
    {
      "name": "test-unixlike-gcc-release",
      "displayName": "Strict",
      "description": "Enable output and stop on failure",
      "inherits": "test-common",
      "configurePreset": "unixlike-gcc-release"
    },
    {
      "name": "test-unixlike-clang-debug",
      "displayName": "Strict",
      "description": "Enable output and stop on failure",
      "inherits": "test-common",
      "configurePreset": "unixlike-clang-debug"
    },
    {
      "name": "test-unixlike-clang-release",
      "displayName": "Strict",
      "description": "Enable output and stop on failure",
      "inherits": "test-common",
      "configurePreset": "unixlike-clang-release"
    }
  ],
  "packagePresets": [
    {
      "name": "package-common",
      "description": "Common settings for packages",
      "hidden": true,
      "configurations": ["Release"],
      "variables": {
        "CPACK_PACKAGE_DIRECTORY": "${sourceDir}/out/packages/${presetName}",
        "CPACK_PACKAGE_NAME": "cpp_proj_template",
        "CPACK_PACKAGE_INSTALL_DIRECTORY": "cpp_proj_template",
        "CPACK_VERBATIM_VARIABLES": "YES"
      }
    },
    {
      "name": "package-windows",
      "displayName": "Windows Package",
      "description": "Create ZIP packages on Windows",
      "inherits": "package-common",
      "configurePreset": "windows-msvc-release",
      "generators": ["ZIP"]
    },
    {
      "name": "package-unixlike-gcc",
      "displayName": "Unix GCC Package",
      "description": "Create TGZ and DEB packages on Unix-like systems with GCC",
      "inherits": "package-common",
      "configurePreset": "unixlike-gcc-release",
      "generators": ["TGZ", "DEB"]
    },
    {
      "name": "package-unixlike-clang",
      "displayName": "Unix Clang Package",
      "description": "Create TGZ and DEB packages on Unix-like systems with Clang",
      "inherits": "package-common",
      "configurePreset": "unixlike-clang-release",
      "generators": ["TGZ", "DEB"]
    }
  ],
  "workflowPresets": [
    {
      "name": "clang-test-workflow",
      "displayName": "Clang Default Workflow",
      "description": "Configure, build, test, and package with Clang in one step",
      "steps": [
        {
          "type": "configure",
          "name": "unixlike-clang-release"
        },
        {
          "type": "build",
          "name": "unixlike-clang-release"
        },
        {
          "type": "test",
          "name": "test-unixlike-clang-release"
        }
      ]
    },
    {
      "name": "gcc-test-workflow",
      "displayName": "GCC Default Workflow",
      "description": "Configure, build, test, and package with GCC in one step",
      "steps": [
        {
          "type": "configure",
          "name": "unixlike-gcc-release"
        },
        {
          "type": "build",
          "name": "unixlike-gcc-release"
        },
        {
          "type": "test",
          "name": "test-unixlike-gcc-release"
        }
      ]
    },
    {
      "name": "windows-test-workflow",
      "displayName": "Windows Default Workflow",
      "description": "Configure, build, test, and package on Windows in one step",
      "steps": [
        {
          "type": "configure",
          "name": "windows-msvc-release"
        },
        {
          "type": "build",
          "name": "windows-msvc-release"
        },
        {
          "type": "test",
          "name": "test-windows-msvc-release"
        }
      ]
    },
    {
      "name": "package-clang-workflow",
      "displayName": "Clang Package Workflow",
      "description": "Configure, build, test, and package with Clang in release mode",
      "steps": [
        {
          "type": "configure",
          "name": "unixlike-clang-release"
        },
        {
          "type": "build",
          "name": "unixlike-clang-release"
        },
        {
          "type": "test",
          "name": "test-unixlike-clang-release"
        },
        {
          "type": "package",
          "name": "package-unixlike-clang"
        }
      ]
    },
    {
      "name": "package-windows-workflow",
      "displayName": "Windows Package Workflow",
      "description": "Configure, build, test, and package on Windows in release mode",
      "steps": [
        {
          "type": "configure",
          "name": "windows-msvc-release"
        },
        {
          "type": "build",
          "name": "windows-msvc-release"
        },
        {
          "type": "test",
          "name": "test-windows-msvc-release"
        },
        {
          "type": "package",
          "name": "package-windows"
        }
      ]
    }
  ]
}